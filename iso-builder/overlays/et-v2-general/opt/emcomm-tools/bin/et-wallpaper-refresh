#!/bin/bash
#
# Author  : Sylvain Deguire (VA2OPS)
# Date    : March 2026
# Purpose : Force XFCE to re-render wallpaper after display scaling is applied.
#           On HiDPI screens (scale 2.5, 1.25, etc.), xfdesktop renders the
#           wallpaper before scaling kicks in, showing only the top-left portion.
#           Toggling the image-style property forces a correct re-render.

# Wait until xfdesktop is fully running — poll for the process itself
for i in $(seq 1 60); do
    pgrep -x xfdesktop > /dev/null 2>&1 && break
    sleep 1
done

# Wait until xfdesktop has registered its xfconf properties (up to 30s)
for i in $(seq 1 30); do
    PROPS=$(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep image-style)
    [ -n "$PROPS" ] && break
    sleep 1
done

# Set image-style=5 (Zoomed) on all existing backdrop paths
while IFS= read -r prop; do
    xfconf-query -c xfce4-desktop -p "$prop" -s 5 2>/dev/null
done < <(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep image-style)

# Also create image-style=5 for common monitor name formats.
# XFCE may use numeric indices (monitor0) or XRandR names (monitorHDMI-1)
# depending on version — cover both so one of them sticks.
SCREEN="screen0"
WORKSPACES=$(xfconf-query -c xfwm4 -p /general/workspace_count 2>/dev/null || echo 1)

# Numeric indices (monitor0, monitor1, ...)
MON_COUNT=$(xrandr --listmonitors 2>/dev/null | awk 'NR==1{print $2}')
for idx in $(seq 0 $(( ${MON_COUNT:-1} - 1 ))); do
    for ws in $(seq 0 $(( WORKSPACES - 1 ))); do
        prop="/backdrop/${SCREEN}/monitor${idx}/workspace${ws}/image-style"
        xfconf-query -c xfce4-desktop -p "$prop" -s 5 --create -t int 2>/dev/null || \
        xfconf-query -c xfce4-desktop -p "$prop" -s 5 2>/dev/null
    done
done

# XRandR output names (monitorHDMI-1, monitoreDP-1, ...)
for monitor in $(xrandr --listmonitors 2>/dev/null | awk 'NR>1 {print $NF}'); do
    for ws in $(seq 0 $(( WORKSPACES - 1 ))); do
        prop="/backdrop/${SCREEN}/monitor${monitor}/workspace${ws}/image-style"
        xfconf-query -c xfce4-desktop -p "$prop" -s 5 --create -t int 2>/dev/null || \
        xfconf-query -c xfce4-desktop -p "$prop" -s 5 2>/dev/null
    done
done

# Kill and restart xfdesktop so it re-reads xfconf from scratch.
# --reload is unreliable; a clean restart guarantees it picks up image-style=5.
xfdesktop --quit 2>/dev/null || pkill -x xfdesktop 2>/dev/null || true
sleep 2
xfdesktop &

# Ensure xfce4-panel is running — restart it if it crashed during startup
if ! pgrep -x xfce4-panel > /dev/null 2>&1; then
    xfce4-panel &
    sleep 2
fi

# Enable seconds display on the XFCE panel clock
# Find the clock plugin ID and set digital format with seconds
for plugin_id in $(xfconf-query -c xfce4-panel -l 2>/dev/null | grep -oP 'plugin-\d+(?=/type)' | sort -u); do
    plugin_type=$(xfconf-query -c xfce4-panel -p "/$plugin_id/type" 2>/dev/null)
    if [[ "$plugin_type" == "clock" ]]; then
        xfconf-query -c xfce4-panel -p "/$plugin_id/digital-format" \
            -s "%R:%S" --create -t string 2>/dev/null || \
        xfconf-query -c xfce4-panel -p "/$plugin_id/digital-format" \
            -s "%R:%S" 2>/dev/null
        break
    fi
done
